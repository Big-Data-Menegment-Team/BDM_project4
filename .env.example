# Copy to `.env` and adjust if needed. `.env` is gitignored — never commit
# real credentials or the Slack webhook URL.

# --- Postgres (the `rico` data database) ---
POSTGRES_DB=rico
POSTGRES_USER=rico
POSTGRES_PASSWORD=rico

# --- MinIO / S3 ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rico-raw

# --- Ollama ---
OLLAMA_MODEL=qwen2.5:3b

# --- Airflow UI admin user (created once by the airflow-init container) ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# --- Slack (Part C) ---
# Leave blank until Part C wires up notifications. Never commit a real URL.
SLACK_WEBHOOK_URL=
